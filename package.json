{
  "name": "openclaw-channel-multibot",
  "version": "1.0.15",
  "description": "OpenClaw channel plugin that bridges your agents with the multibot mobile app",
  "type": "module",
  "license": "MIT",
  "bin": {
    "multibot-new-code": "bin/new-code.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arturograu/openclaw_channel_multibot"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "multibot",
    "channel"
  ],
  "files": [
    "src",
    "bin",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "src/index.ts"
    ],
    "channel": {
      "id": "multibot",
      "label": "Multibot",
      "selectionLabel": "Multibot App",
      "docsPath": "/channels/multibot",
      "order": 50
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.8.2"
  }
}
