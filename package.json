{
  "name": "openclaw-channel-multibot",
  "version": "1.0.18",
  "description": "OpenClaw channel plugin that bridges your agents with the multibot mobile app",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arturograu/openclaw_channel_multibot"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "multibot",
    "channel"
  ],
  "files": [
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "src/index.ts"
    ],
    "channel": {
      "id": "multibot",
      "label": "Multibot",
      "selectionLabel": "Multibot App",
      "docsPath": "/channels/multibot",
      "order": 50
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
